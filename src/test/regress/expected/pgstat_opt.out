 pg_stat_clear_snapshot 
------------------------
 
(1 row)

SELECT (COALESCE((SELECT calls FROM pg_stat_user_functions WHERE funcname='f_pgstat_test'),0) = 1) AS func_calls_exact;
 func_calls_exact 
