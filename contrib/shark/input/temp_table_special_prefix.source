-- test temporary table with "#" / "##" as prefix name.
CREATE DATABASE temp_table_prefix dbcompatibility 'D';
CREATE DATABASE temp_table_prefix_1 dbcompatibility 'D';
\c temp_table_prefix
create extension shark;
CREATE SCHEMA test_temp_table_prefix;
SET current_schema = test_temp_table_prefix;

-- case1: create 
CREATE TABLE #Employee (
    ID INT,
    Name NVARCHAR(50),
    HireDate DATE
);

CREATE TABLE ##GlobalLog (
    LogID INT,
    Message NVARCHAR(100)
);

SELECT relname, relpersistence FROM pg_class WHERE relname = '#employee';
SELECT relname, relpersistence FROM pg_class WHERE relname = '##globallog';

-- error
CREATE TABLE #Employee (
    ID INT,
    Name NVARCHAR(50),
    HireDate DATE
);
-- error
CREATE TABLE ##GlobalLog (
    LogID INT,
    Message NVARCHAR(100)
);

-- error, not support partition table.
CREATE TABLE #PartitionedTemp (
    id INT,
    dt DATE
) PARTITION BY RANGE (dt) (
    PARTITION p1 VALUES LESS THAN ('2022-01-01'),
    PARTITION p_default VALUES LESS THAN (MAXVALUE)
);

CREATE TABLE ##PartitionedTemp (
    id INT,
    dt DATE
) PARTITION BY RANGE (dt) (
    PARTITION p1 VALUES LESS THAN ('2022-01-01'),
    PARTITION p_default VALUES LESS THAN (MAXVALUE)
);

--Case insensitive,
CREATE TABLE #aa (ID INT);
-- duplicate error.
CREATE TABLE #Aa (ID INT);
CREATE TABLE ##aa (ID INT);
-- duplicate error.
CREATE TABLE ##Aa (ID INT);

INSERT INTO ##Aa VALUES(1);
SELECT * FROM ##Aa LIMIT 1;

-- with schema qualified.
CREATE TABLE test_temp_table_prefix.#Employee1 (ID INT, Name NVARCHAR(50));
CREATE TABLE test_temp_table_prefix.##GlobalLog1 (LogID INT, Message NVARCHAR(100));

SELECT relname, relpersistence FROM pg_class WHERE relname = '#employee1';
SELECT relname, relpersistence FROM pg_class WHERE relname = '##globallog1';

-- with catalog and schema qualified.
CREATE TABLE temp_table_prefix.test_temp_table_prefix.#Employee2 (ID INT, Name NVARCHAR(50));
CREATE TABLE temp_table_prefix.test_temp_table_prefix.##GlobalLog2 (LogID INT, Message NVARCHAR(100));

SELECT relname, relpersistence FROM pg_class WHERE relname = '#employee2';
SELECT relname, relpersistence FROM pg_class WHERE relname = '##globallog2';

-- case2: insert
INSERT INTO #Employee VALUES (1, 'Alice', '2023-01-01');
INSERT INTO ##GlobalLog VALUES (1, 'Test Message');

-- case3: select
SELECT * FROM #Employee;
SELECT * FROM ##GlobalLog;

SELECT * FROM test_temp_table_prefix.#Employee;
SELECT * FROM test_temp_table_prefix.##GlobalLog;

SELECT * FROM test_temp_table_prefix.#Employee;
SELECT * FROM test_temp_table_prefix.##GlobalLog;

SELECT * FROM temp_table_prefix.test_temp_table_prefix.#Employee;
SELECT * FROM temp_table_prefix.test_temp_table_prefix.##GlobalLog;


-- case4: update
UPDATE #Employee SET Name = 'xxx' WHERE ID = 1;
UPDATE ##GlobalLog SET Message = 'message' WHERE LogID = 1;


-- case5: drop
DROP TABLE #Employee;
DROP TABLE ##GlobalLog;

-- case6: select into
CREATE TABLE test1(a int, b int);
INSERT INTO test1 VALUES (1, 1), (2, 2);
SELECT * INTO #test_t1 FROM test1;
SELECT relname, relpersistence FROM pg_class WHERE relname = '#test_t1';
SELECT * FROM #test_t1 order by a;

SELECT * INTO ##test_t2 FROM test1;
SELECT relname, relpersistence FROM pg_class WHERE relname = '##test_t2';
SELECT * FROM ##test_t2 order by a;

SELECT * INTO #test_t3 FROM ##test_t2;
SELECT relname, relpersistence FROM pg_class WHERE relname = '#test_t3';
SELECT * FROM #test_t3 order by a;

-- case7: create as
CREATE TABLE cas_test (id int, name varchar);
INSERT INTO cas_test VALUES(1, 'xxx');

CREATE TABLE #cas_temp1 AS SELECT id, name FROM cas_test;
SELECT relname, relpersistence FROM pg_class WHERE relname = '#cas_temp1';
SELECT * FROM #cas_temp1;

CREATE TABLE ##Cas_temp1 AS SELECT id, name FROM cas_test;

-- case8: #, ## as operator
-- error
CREATE TABLE # (
    ID INT
);
-- error
CREATE TABLE ## (
    ID INT
);
-- success
CREATE TABLE ### (
    ID INT
);

CREATE TABLE #111 (
    ID INT
);
INSERT INTO #111 VALUES(1);

-- create operator
CREATE FUNCTION square(a int) 
RETURNS int AS $$
BEGIN
    RETURN a * a;
END;
$$ LANGUAGE plpgsql;
CREATE OPERATOR # (
    PROCEDURE = square,
    RIGHTARG = int
);

-- should be reconginzed as operator, regardless of enable_special_operator
SELECT 1 # 1;
SELECT '1' # 1;
SELECT b'0' # b'1';

SELECT LINE'((0,0),(1,1))' # LINE'((0,1),(1,0))';
SELECT BOX'(0,0,2,2)' # BOX'(1,1,3,3)';
SELECT LSEG'((0,0),(2,2))' # LSEG'((1,1),(3,3))';

SELECT POINT(1,1) ## LINE'((0,0),(2,2))';
SELECT POINT(1,1) ## LSEG'((0,0),(2,2))';
SELECT POINT(1,1) ## BOX'(0,0,2,2)';
SELECT LSEG'((0,0),(1,1))' ## LINE'((1,1),(2,0))';
SELECT LSEG'((0,0),(1,1))' ## LSEG'((1,1),(2,2))';
SELECT LSEG'((0,0),(0,3))' ## BOX'(0,0,2,2)';
SELECT LINE'((0,1),(3,1))' ## BOX'(0,0,3,2)';
SELECT LINE'((1,1),(2,0))' ## LSEG'((0,0),(1,1))';

-- #### test GUC parameter
-- default: enable_special_operator=false, reconginzed as IDNET
SELECT 1#1;
SELECT '1'#1;
SELECT 1 #abs(-1);
SELECT b'0'#b'1';
SELECT # 2;
SELECT #2;

SELECT #'((0,0), (1,1))'::POLYGON;
SELECT #'((0,0),(1,1),(2,0))'::PATH;
SELECT #((0, 0), (1, 1));

SELECT #POLYGON'((0, 0), (1, 1))';
SELECT LINE'((0,0),(1,1))' #LINE'((0,1),(1,0))';
SELECT BOX'(0,0,2,2)' #BOX'(1,1,3,3)';
SELECT LSEG'((0,0),(2,2))' #LSEG'((1,1),(3,3))';
SELECT POINT(1,1) ##LINE'((0,0),(2,2))';
SELECT POINT(1,1) ##LSEG'((0,0),(2,2))';
SELECT POINT(1,1) ##BOX'(0,0,2,2)';
SELECT LSEG'((0,0),(1,1))' ##LINE'((1,1),(2,0))';
SELECT LSEG'((0,0),(1,1))' ##LSEG'((1,1),(2,2))';
SELECT LSEG'((0,0),(0,3))' ##BOX'(0,0,2,2)';
SELECT LINE'((0,1),(3,1))' ##BOX'(0,0,3,2)';
SELECT LINE'((1,1),(2,0))' ##LSEG'((0,0),(1,1))';

DECLARE
    a int;
BEGIN
    SELECT 1 # 1 INTO a;
    RAISE INFO 'a: %', a;
    -- success
    SELECT 1 ##111.ID INTO a FROM #111 WHERE ID = 1;
    RAISE INFO 'a: %', a;
END;
/

SELECT 1 # #111.ID from #111 where ID = 1;
SELECT 1 ##111.ID from #111 where ID = 1;

-- enable_special_operator=true, reconginzed as Op
set enable_special_operator = true;
SELECT 1#1;
SELECT '1'#1;
SELECT 1 #abs(-1);
SELECT b'0'#b'1';
SELECT # 2;
SELECT #2;

SELECT #'((0,0), (1,1))'::POLYGON;
SELECT #'((0,0),(1,1),(2,0))'::PATH;
SELECT #((0, 0), (1, 1));

SELECT #POLYGON'((0, 0), (1, 1))';
SELECT LINE'((0,0),(1,1))'#LINE'((0,1),(1,0))';
SELECT BOX'(0,0,2,2)' #BOX'(1,1,3,3)';
SELECT LSEG'((0,0),(2,2))'#LSEG'((1,1),(3,3))';
SELECT POINT(1,1)##LINE'((0,0),(2,2))';
SELECT POINT(1,1)##LSEG'((0,0),(2,2))';
SELECT POINT(1,1)##BOX'(0,0,2,2)';
SELECT LSEG'((0,0),(1,1))'##LINE'((1,1),(2,0))';
SELECT LSEG'((0,0),(1,1))'##LSEG'((1,1),(2,2))';
SELECT LSEG'((0,0),(0,3))'##BOX'(0,0,2,2)';
SELECT LINE'((0,1),(3,1))'##BOX'(0,0,3,2)';
SELECT LINE'((1,1),(2,0))'##LSEG'((0,0),(1,1))';

DECLARE
    a int;
BEGIN
    SELECT 1 # 1 INTO a;
    RAISE INFO 'a: %', a;
    -- success
    SELECT 1 ##111.ID INTO a FROM #111 WHERE ID = 1;
    RAISE INFO 'a: %', a;
END;
/

SELECT 1 # #111.ID from #111 where ID = 1;
SELECT 1 ##111.ID from #111 where ID = 1;

reset enable_special_operator;

-- nested GUC parameter in plsql
DECLARE
    a int;
BEGIN
    SELECT 1 # 1 INTO a;
    RAISE INFO 'a: %', a;
    set enable_special_operator = true;
    -- success
    SELECT 1 ##111.ID INTO a FROM #111 WHERE ID = 1;
    RAISE INFO 'a: %', a;
END;
/

-- noraml IDENT case
CREATE TEMP TABLE t1 (a int);
CREATE TEMP TABLE IF NOT EXISTS t2 (a int);

CREATE TABLE t3 AS SELECT * FROM t1;
SELECT * INTO t4 FROM t1;

CREATE TYPE typ1 AS (
  product_id INT,
  stock INT
);
CREATE TABLE t5 OF typ1;
CREATE TABLE IF NOT EXISTS t6 OF typ1;

-- dump/restore
CREATE TABLE #Employee (
    ID INT,
    Name NVARCHAR(50),
    HireDate DATE
);

CREATE TABLE ##GlobalLog (
    LogID INT,
    Message NVARCHAR(100)
);
\! @abs_bindir@/gs_dump temp_table_prefix -p @portstring@ -f @abs_bindir@/dump_temp_table_prefix.tar -F t >/dev/null 2>&1; echo $?
\! @abs_bindir@/gs_restore -d temp_table_prefix_1 -p @portstring@ @abs_bindir@/dump_temp_table_prefix.tar >/dev/null 2>&1; echo $?
\c temp_table_prefix_1

-- local temporary table not dumped
SELECT relname, relpersistence FROM pg_class WHERE relname = '#employee';
SELECT relname, relpersistence FROM pg_class WHERE relname = '##globallog';

SELECT 1#1;
SELECT 1 # 1;
SELECT 1 # #111.ID from #111 where ID = 1;
set enable_special_operator = true;
SELECT 1#1;
SELECT 1 # 1;
SELECT 1 # #111.ID from #111 where ID = 1;
reset enable_special_operator;

-- special character in table name
--本地临时表
--中文、数字、字母、特殊字符@#_ --成功
create table #测试test_temp_table( col1 int primary key );
create table #123test_temp_table( col1 int primary key );
create table #test_temp_table( col1 int primary key );
create table #@test_temp_table( col1 int primary key );
create table #_test_temp_table(
col1 int primary key
);

--本地临时表-特殊字符、空格 --报错
create table #.test_temp_table(
col1 int primary key
);
create table # test_temp_table(
col1 int primary key
);

--全局临时表--中文、数字、字母、特殊字符@#_ --成功
create table ##测试test_temp_table( col1 int primary key );
create table ##123test_temp_table( col1 int primary key );
create table ##test_temp_table( col1 int primary key );
create table ##@test_temp_table( col1 int primary key );
create table ###test_temp_table(
col1 int primary key
);
create table ##_test_temp_table(
col1 int primary key
);
--全局临时表-特殊字符、空格 --报错
create table ##.test_temp_table(
col1 int primary key
);
create table ## test_temp_table(
col1 int primary key
);
--列存表
create table #test_temp_table_2(
col1 int primary key,
col2 char(10)
)WITH (ORIENTATION = COLUMN);
-- with schema pg_temp
create table pg_temp.#test_temp_table_2(
col1 int primary key,
col2 char(10)
)WITH (ORIENTATION = COLUMN);

--外键1-本表为临时表，被引用表为临时表
create table #test_temp_table_3(
col1 int,
col2 char(10) primary key
);
insert into #test_temp_table_3 values(1,'test');
insert into #test_temp_table_3 values(2,'vast');
insert into #test_temp_table_3 values(3,'coast');
insert into #test_temp_table_3 values(4,'fast');
create table #test_temp_foreign_table_3(
col1 int,
col2 char(20) references #test_temp_table_3(col2)
);
insert into #test_temp_foreign_table_3 values(6,'fast');
insert into #test_temp_foreign_table_3 values(8,'best');
--外键2-本表为临时表，被引用表为非临时表
create table test_temp_table_3_1(
col1 int,
col2 char(10) primary key
);
insert into test_temp_table_3_1 values(1,'test');
insert into test_temp_table_3_1 values(2,'vast');
insert into test_temp_table_3_1 values(3,'coast');
insert into test_temp_table_3_1 values(4,'fast');
create table #test_temp_foreign_table_3_1(
col1 int,
col2 char(20) references test_temp_table_3_1(col2)
);
insert into #test_temp_foreign_table_3_1 values(6,'fast');
insert into #test_temp_foreign_table_3_1 values(8,'best');
--外键3-本表为实体表，被引用表为临时表
create table #test_temp_table_3_2(
col1 int,
col2 char(10) primary key
);
insert into #test_temp_table_3_2 values(1,'test');
create table test_temp_foreign_table_3_2(
col1 int,
col2 char(20) references #test_temp_table_3_2(col2)
);

-- alter table add constraint foreign key in D-format
create table #test_temp_table_4(
col1 int,
col2 char(10) primary key
);
insert into #test_temp_table_4 values(1,'test');
insert into #test_temp_table_4 values(2,'vast');
insert into #test_temp_table_4 values(3,'coast');
insert into #test_temp_table_4 values(4,'fast');
create table #test_temp_foreign_table_4(
col1 int,
col2 char(20)
);
alter table #test_temp_foreign_table_4 add foreign key (col2) references #test_temp_table_4(col2);
insert into #test_temp_foreign_table_4 values(6,'fast');
insert into #test_temp_foreign_table_4 values(8,'best');
-- clean
\c postgres
DROP DATABASE temp_table_prefix;
DROP DATABASE temp_table_prefix_1;
