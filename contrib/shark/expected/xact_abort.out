CREATE OR replace PROCEDURE d_dbproc.proc4() AS
BEGIN
        RAISE EXCEPTION 'raise exception';
        EXCEPTION
        WHEN OTHERS THEN
           insert into t1 values(1, 'lisi');
           insert into t1 values(2, 'wanger');
END;
/
CALL d_dbproc.proc4();
