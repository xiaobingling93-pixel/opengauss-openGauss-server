drop table if exists department;
drop table if exists staff;
create table staff1 (
    id          int primary key not null,
    name        text not null,
    age         int not null,
    address     char(50),
    salary      real
);
NOTICE:  CREATE TABLE / PRIMARY KEY will create implicit index "staff1_pkey" for table "staff1"
create table department1 (
    id          int primary key not null,
    dept        char(50) not null,
    emp_id      int,
    constraint my_fkey foreign key (emp_id) references staff1(id) on update set null on delete cascade
);
NOTICE:  CREATE TABLE / PRIMARY KEY will create implicit index "department1_pkey" for table "department1"
