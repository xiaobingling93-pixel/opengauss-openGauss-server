create table staff (
    id          int primary key not null,
    name        text not null,
    age         int not null,
    address     char(50),
    salary      real
);
NOTICE:  CREATE TABLE / PRIMARY KEY will create implicit index "staff_pkey" for table "staff"
create table department (
    id          int primary key not null,
    dept        char(50) not null,
    emp_id      int references staff(id) on update cascade on delete set default
);
NOTICE:  CREATE TABLE / PRIMARY KEY will create implicit index "department_pkey" for table "department"
