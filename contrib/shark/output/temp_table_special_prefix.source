-- test temporary table with "#" / "##" as prefix name.
CREATE DATABASE temp_table_prefix dbcompatibility 'D';
CREATE DATABASE temp_table_prefix_1 dbcompatibility 'D';
\c temp_table_prefix
create extension shark;
\c temp_table_prefix_1;
create extension shark;
\c temp_table_prefix
CREATE SCHEMA test_temp_table_prefix;
SET current_schema = test_temp_table_prefix;
-- case1: create 
CREATE TABLE #Employee (
    ID INT,
    Name NVARCHAR(50),
    HireDate DATE
);
CREATE TABLE ##GlobalLog (
    LogID INT,
    Message NVARCHAR(100)
);
SELECT relname, relpersistence FROM pg_class WHERE relname = '#employee';
  relname  | relpersistence 
-----------+----------------
 #employee | t
(1 row)

SELECT relname, relpersistence FROM pg_class WHERE relname = '##globallog';
   relname   | relpersistence 
-------------+----------------
 ##globallog | g
(1 row)

-- error
CREATE TABLE #Employee (
    ID INT,
    Name NVARCHAR(50),
    HireDate DATE
);
--?ERROR:  relation "#employee" already exists in schema .*
DETAIL:  creating new table with existing name in the same schema
-- error
CREATE TABLE ##GlobalLog (
    LogID INT,
    Message NVARCHAR(100)
);
ERROR:  relation "##globallog" already exists in schema "test_temp_table_prefix"
DETAIL:  creating new table with existing name in the same schema
-- error, not support partition table.
CREATE TABLE #PartitionedTemp (
    id INT,
    dt DATE
) PARTITION BY RANGE (dt) (
    PARTITION p1 VALUES LESS THAN ('2022-01-01'),
    PARTITION p_default VALUES LESS THAN (MAXVALUE)
);
ERROR:  unsupported feature with temporary/unlogged table for partitioned table
CREATE TABLE ##PartitionedTemp (
    id INT,
    dt DATE
) PARTITION BY RANGE (dt) (
    PARTITION p1 VALUES LESS THAN ('2022-01-01'),
    PARTITION p_default VALUES LESS THAN (MAXVALUE)
);
ERROR:  unsupported feature with temporary/unlogged table for partitioned table
--Case insensitive,
CREATE TABLE #aa (ID INT);
-- duplicate error.
CREATE TABLE #Aa (ID INT);
--?ERROR:  relation "#aa" already exists in schema .*
DETAIL:  creating new table with existing name in the same schema
CREATE TABLE ##aa (ID INT);
-- duplicate error.
CREATE TABLE ##Aa (ID INT);
ERROR:  relation "##aa" already exists in schema "test_temp_table_prefix"
DETAIL:  creating new table with existing name in the same schema
INSERT INTO ##Aa VALUES(1);
SELECT * FROM ##Aa LIMIT 1;
 id 
----
  1
(1 row)

