NOTICE:  CREATE TABLE / PRIMARY KEY will create implicit index "#test_temp_table_pkey" for table "#test_temp_table"
create table #@test_temp_table( col1 int primary key );
NOTICE:  CREATE TABLE / PRIMARY KEY will create implicit index "#@test_temp_table_pkey" for table "#@test_temp_table"
