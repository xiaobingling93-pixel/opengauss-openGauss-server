DO $$
DECLARE
    v_name varchar(50);
    v_sSample varchar(20) := 'a';
BEGIN
    DROP TABLE IF EXISTS #test_temp_table_1;

    SELECT id INTO #test_temp_table_1
    FROM tab 
    WHERE name = v_sSample;

    GET DIAGNOSTICS v_name = ROW_COUNT;
    RAISE NOTICE 'Success: Created temp table with % rows.', v_name;

END $$;
