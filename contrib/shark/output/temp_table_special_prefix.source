-- noraml IDENT case
CREATE TEMP TABLE t1 (a int);
CREATE TEMP TABLE IF NOT EXISTS t2 (a int);
CREATE TABLE t3 AS SELECT * FROM t1;
SELECT * INTO t4 FROM t1;
CREATE TYPE typ1 AS (
  product_id INT,
  stock INT
);
CREATE TABLE t5 OF typ1;
CREATE TABLE IF NOT EXISTS t6 OF typ1;
-- dump/restore
CREATE TABLE #Employee (
    ID INT,
    Name NVARCHAR(50),
    HireDate DATE
);
