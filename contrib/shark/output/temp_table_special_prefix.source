    ID INT
);
CREATE TABLE #111 (
    ID INT
);
INSERT INTO #111 VALUES(1);
-- create operator
CREATE FUNCTION square(a int) 
RETURNS int AS $$
BEGIN
    RETURN a * a;
END;
$$ LANGUAGE plpgsql;
CREATE OPERATOR # (
    PROCEDURE = square,
    RIGHTARG = int
);
